{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":prHourlyLimitNone",
    ":prImmediately",
    ":semanticCommitTypeAll(build)",
    ":separateMajorReleases"
  ],
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "rangeStrategy": "bump",
  // Dependabot owns security remediation (it works off the full dependency
  // graph and catches Gradle transitive CVEs that Renovate cannot bump:
  // no lockfile, no transitive-override mechanism). Disable Renovate's
  // duplicate vuln PRs so the two bots don't race. Renovate = version
  // updates only.
  "vulnerabilityAlerts": { "enabled": false },
  // Lock file maintenance refreshes the whole lockfile to the newest
  // resolvable versions and bypasses minimumReleaseAge, so disable it to keep
  // the 7-day cooldown airtight (Dependabot covers vulnerable transitives).
  "lockFileMaintenance": { "enabled": false },
  "packageRules": [
    {
      // Do NOT pin devDependencies. Renovate's pin step ignores release age,
      // which sidesteps the 7-day cooldown. These are npm dev tooling only, so
      // keep semver ranges and let the normal (cooled) update flow govern.
      // This overrides config:best-practices' :pinDevDependencies; a bare
      // :preserveSemverRanges would not, since a packageRule beats a top-level
      // rangeStrategy.
      "matchDepTypes": ["devDependencies"],
      "rangeStrategy": "bump"
    },
    {
      // Flying Saucer requires Java 11 in 9.5.0, and Java 17 in 9.6.0 (https://github.com/flyingsaucerproject/flyingsaucer?tab=readme-ov-file#getting-flying-saucer),
      // so these changes are pending that, since we're still targeting Java 8.
      "matchPackageNames": ["org.xhtmlrenderer:flying-saucer-core"],
      "allowedVersions": "<9.5.0"
    },
    {
      "matchPackageNames": ["edu.sc.seis.launch4j:edu.sc.seis.launch4j.gradle.plugin"],
      "changelogUrl": "https://github.com/TheBoegl/gradle-launch4j/releases"
    },
    {
      "matchPackageNames": ["commons-io:commons-io"],
      "changelogUrl": "https://commons.apache.org/proper/commons-io/changes.html"
    },
    {
      "matchPackageNames": ["commons-codec:commons-codec"],
      "changelogUrl": "https://commons.apache.org/proper/commons-codec/changes.html"
    },
    {
      "matchPackageNames": ["org.apache.commons:commons-lang3"],
      "changelogUrl": "https://commons.apache.org/proper/commons-lang/changes.html"
    },
    {
      "matchPackageNames": ["com.google.oauth-client:*"],
      "groupName": "google-oauth-client"
    },
    {
      "matchPackageNames": ["com.google.http-client:*"],
      "groupName": "google-http-client"
    }
  ]
}
